# Build output
/target/

# Uncompressed vendor sources — tracked as vendor.tar.xz instead
/vendor/

# Logs and temp files
*.log
*.tmp
*.bak

# OS artefacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Secrets / local env
.env

# Local test output (not for commit)
out/
out.7z
tmp-sloc/

# Loose report artefacts from local runs
result.json
result.html
result.pdf

# Coverage / profiling (cargo-llvm-cov, grcov, cargo-flamegraph)
*.profraw
*.profdata
lcov.info
flamegraph.svg
perf.data
perf.data.old

# Uncompressed extracted binaries in dist/ — only the zip/tar.gz bundles are tracked
/dist/oxidesloc
/dist/oxidesloc.exe
/dist/oxide-sloc-*
/dist/tmp-*/

# Duplicate compressed Windows binary — .zip already covers this and extracts natively on Windows
/dist/oxidesloc-windows-x64.7z

# Transferable bundle archives created by `make bundle`
/oxide-sloc-bundle*.7z
/oxide-sloc-bundle*.tar.gz

# Claude Code (project-local AI context — not for commit)
CLAUDE.md
.claude