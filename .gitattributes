# Normalize all text files to LF on commit (no CRLF in the repo)
* text=auto eol=lf

# Explicitly mark known binary file types globally
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.wasm binary
*.o binary
*.a binary
*.lib binary
*.fst binary
*.dfa binary
*.der binary

# Vendor sources must never be normalized by git — cargo checksum verification
# compares the exact bytes on disk to the SHA-256 in .cargo-checksum.json.
# If git rewrites CRLF→LF (or vice-versa) in any vendor file, the checksum
# will not match and cargo will refuse to build.  Use -text to disable all
# line-ending processing for every file under vendor/.
vendor/** -text

# Our own source and static assets: normalize to LF
crates/**/*.rs   text eol=lf
crates/**/*.toml text eol=lf
crates/**/*.json text eol=lf
crates/sloc-web/static/*.js text eol=lf
